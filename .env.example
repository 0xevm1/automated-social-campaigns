# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_IMAGE_MODEL=
LOG_LEVEL=info

# AWS / LocalStack
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=asc-campaign-assets
SNS_TOPIC_ARN_PREFIX=arn:aws:sns:us-east-1:000000000000:
SQS_QUEUE_URL_PREFIX=http://localhost:4566/000000000000/
DYNAMO_TABLE_NAME=asc-campaigns

# Google OAuth (Gmail + Drive watchers)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
# GOOGLE_TOKEN_PATH=.google-token.json
# GMAIL_LABEL=campaign-briefs
# GOOGLE_DRIVE_FOLDER_ID=

# Microsoft (Outlook watcher)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# OUTLOOK_FOLDER=Inbox
# OUTLOOK_USER_ID=me

# Campaign Runner
# STATUS_PORT=3001
