{
  "name": "automated-social-campaigns",
  "version": "2.0.0",
  "description": "Distributed creative automation pipeline for social ad campaigns",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4569",
    "build": "tsc --build tsconfig.build.json",
    "build:ui": "next build",
    "start": "next start --port 4569",
    "dev:intake": "pnpm --filter @asc/intake dev",
    "dev:processing": "pnpm --filter @asc/processing dev",
    "dev:runner": "pnpm --filter @asc/campaign-runner dev",
    "test": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "setup:local": "./scripts/setup-local.sh",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up --build --force-recreate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@asc/shared": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
